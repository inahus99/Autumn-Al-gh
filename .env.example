# GitHub Personal Access Token (required)
# Scopes needed: read:org, read:user, public_repo
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Slack incoming webhook URL (optional)
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx

# HubSpot private app token (optional)
# Create at: https://app.hubspot.com/private-apps
HUBSPOT_API_KEY=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Hunter.io API key for email enrichment (optional, 25 free/month)
# Get at: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_key_here
