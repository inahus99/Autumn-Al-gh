{
  "name": "gh-signal",
  "version": "0.1.0",
  "description": "GitHub buying signal monitor for B2B sales teams",
  "type": "module",
  "bin": {
    "gh-signal": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "watch": "tsx src/cli/index.ts watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "sales",
    "github",
    "signal",
    "gtm",
    "prospecting",
    "outbound"
  ],
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@octokit/graphql": "^8.1.1",
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "@vitest/coverage-v8": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
